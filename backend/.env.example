# Backend-local env file, used when running uvicorn directly (outside Docker Compose).
# Mirrors the relevant subset of the root .env.example — keep in sync.

ENVIRONMENT=development
PROJECT_NAME="Tarachand Rana Portfolio"
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://portfolio:change-me@localhost:5432/portfolio
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:5173

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CONTACT_NOTIFY_EMAIL=

GITHUB_USERNAME=
GITHUB_API_TOKEN=

RATE_LIMIT_PER_MINUTE=60
