# =============================================================================
# Root environment file — used by docker-compose to configure all services.
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- General ---
ENVIRONMENT=development
PROJECT_NAME="Tarachand Rana Portfolio"
API_V1_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DB=portfolio
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://portfolio:change-me@postgres:5432/portfolio

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Security / JWT ---
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:5173

# --- Admin access control ---
# Only these emails may ever hold an admin session (password login or OAuth).
# There is no public self-registration endpoint.
ALLOWED_ADMIN_EMAILS=you@example.com

# Leave blank normally. Set temporarily in production to create the first admin
# via POST /auth/bootstrap-admin, then remove it — see docs/deployment.md.
BOOTSTRAP_SECRET=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Mail / Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
CONTACT_NOTIFY_EMAIL=

# --- GitHub API (for stats section) ---
GITHUB_USERNAME=
GITHUB_API_TOKEN=

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api/v1
VITE_GITHUB_USERNAME=
VITE_LEETCODE_USERNAME=
VITE_GA_MEASUREMENT_ID=

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60
